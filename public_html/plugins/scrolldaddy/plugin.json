{
    "name": "ScrollDaddy HTML5",
    "version": "1.0.0",
    "description": "Self-hosted DNS filtering service with per-device filtering profiles (HTML5 theme version)",
    "author": "System Developer",
    "is_stock": true,
    "provides_theme": true,
    "requires": {
        "php": ">=8.0",
        "extensions": []
    },
    "settings": [
        { "name": "scrolldaddy_dns_host", "default": "" },
        { "name": "scrolldaddy_dns_internal_url", "default": "" },
        { "name": "scrolldaddy_dns_api_key", "default": "" },
        { "name": "scrolldaddy_dns_server_ip", "default": "" },
        { "name": "scrolldaddy_dns_secondary_internal_url", "default": "" },
        { "name": "scrolldaddy_dns_secondary_api_key", "default": "" },
        { "name": "scrolldaddy_dns_secondary_server_ip", "default": "" },
        { "name": "scrolldaddy_blocklist_version", "default": "" }
    ]
}
