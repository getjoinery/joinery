{
    "title": "Video Embed",
    "description": "Responsive YouTube or Vimeo video embed",
    "category": "media",
    "config_schema": {
        "fields": [
            {
                "name": "heading",
                "label": "Heading",
                "type": "textinput"
            },
            {
                "name": "video_url",
                "label": "Video URL",
                "type": "textinput",
                "help": "YouTube or Vimeo URL"
            },
            {
                "name": "aspect_ratio",
                "label": "Aspect Ratio",
                "type": "dropinput",
                "default": "16x9",
                "options": {
                    "16x9": "16:9 (Standard)",
                    "4x3": "4:3",
                    "21x9": "21:9 (Cinematic)"
                }
            },
            {
                "name": "caption",
                "label": "Caption",
                "type": "textinput",
                "advanced": true
            }
        ]
    }
}
