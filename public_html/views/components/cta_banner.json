{
    "title": "CTA Banner",
    "description": "Full-width call-to-action banner",
    "category": "conversion",
    "css_framework": "bootstrap",
    "config_schema": {
        "fields": [
            {
                "name": "heading",
                "label": "Heading",
                "type": "textinput",
                "default": "Ready to Get Started?"
            },
            {
                "name": "subheading",
                "label": "Supporting Text",
                "type": "textarea",
                "default": "Join thousands of satisfied customers who have transformed their business with our platform. Start your free trial today."
            },
            {
                "name": "cta_text",
                "label": "Button Text",
                "type": "textinput",
                "default": "Start Free Trial"
            },
            {
                "name": "cta_link",
                "label": "Button Link",
                "type": "textinput",
                "default": "/signup"
            },
            {
                "name": "background_type",
                "label": "Background",
                "type": "dropinput",
                "default": "gradient",
                "options": {
                    "color": "Solid Color",
                    "gradient": "Gradient",
                    "image": "Image"
                }
            },
            {
                "name": "background_color",
                "label": "Background Color",
                "type": "textinput",
                "help": "Hex color (for solid background)",
                "default": "#007bff"
            },
            {
                "name": "gradient_start",
                "label": "Gradient Start",
                "type": "textinput",
                "help": "Hex color, e.g., #667eea",
                "default": "#667eea"
            },
            {
                "name": "gradient_end",
                "label": "Gradient End",
                "type": "textinput",
                "help": "Hex color, e.g., #764ba2",
                "default": "#764ba2"
            },
            {
                "name": "background_image",
                "label": "Background Image",
                "type": "textinput",
                "help": "Path to image file",
                "default": ""
            },
            {
                "name": "text_color",
                "label": "Text Color",
                "type": "textinput",
                "help": "Hex color, e.g., #ffffff",
                "default": "#ffffff"
            }
        ]
    },
    "layout_defaults": {
        "container_width": "standard",
        "max_height": "default"
    }
}
