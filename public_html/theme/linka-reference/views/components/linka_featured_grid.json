{
  "title": "Linka Featured Grid",
  "description": "Grid of featured articles with section title",
  "category": "blog",
  "css_framework": "bootstrap",
  "config_schema": {
    "fields": [
      {"name": "section_title", "label": "Section Title", "type": "textinput", "default": "Featured Posts"},
      {"name": "columns", "label": "Columns", "type": "dropinput", "default": "3", "options": {"2": "2 Columns", "3": "3 Columns", "4": "4 Columns"}},
      {"name": "show_author", "label": "Show Author", "type": "checkboxinput", "default": true},
      {"name": "show_excerpt", "label": "Show Excerpt", "type": "checkboxinput", "default": true},
      {
        "name": "articles",
        "label": "Articles",
        "type": "repeater",
        "fields": [
          {"name": "image", "label": "Image URL", "type": "textinput", "default": "/theme/linka-reference/assets/images/home-one/featured-img/1.jpg"},
          {"name": "category", "label": "Category", "type": "textinput", "default": "Lifestyle"},
          {"name": "author", "label": "Author", "type": "textinput", "default": "Jhona Walker"},
          {"name": "date", "label": "Date", "type": "textinput", "default": "25 Mar 2024"},
          {"name": "title", "label": "Title", "type": "textinput", "default": "The two Important Tools to Reconnect Your Partner"},
          {"name": "excerpt", "label": "Excerpt", "type": "textarea", "default": "Lorem ipsum dolor sit amet consectetur adipisicing elit. Sed asperiores, sequi earum inventore consequuntur voluptates voluptatibus sint fugiat quaerat possimus pariatur voluptatem."},
          {"name": "link", "label": "Link", "type": "textinput", "default": "#"}
        ]
      },
      {"name": "background_color", "label": "Background Color", "type": "textinput", "help": "Leave empty for transparent", "default": ""}
    ]
  }
}
