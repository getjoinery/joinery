{
  "title": "Linka Featured Grid",
  "description": "Grid of featured articles with section title",
  "category": "blog",
  "css_framework": "bootstrap",
  "config_schema": {
    "fields": [
      {"name": "section_title", "label": "Section Title", "type": "textinput"},
      {"name": "columns", "label": "Columns", "type": "dropinput", "options": {"2": "2 Columns", "3": "3 Columns", "4": "4 Columns"}},
      {"name": "show_author", "label": "Show Author", "type": "checkboxinput"},
      {"name": "show_excerpt", "label": "Show Excerpt", "type": "checkboxinput"},
      {
        "name": "articles",
        "label": "Articles",
        "type": "repeater",
        "fields": [
          {"name": "image", "label": "Image URL", "type": "textinput"},
          {"name": "category", "label": "Category", "type": "textinput"},
          {"name": "author", "label": "Author", "type": "textinput"},
          {"name": "date", "label": "Date", "type": "textinput"},
          {"name": "title", "label": "Title", "type": "textinput"},
          {"name": "excerpt", "label": "Excerpt", "type": "textarea"},
          {"name": "link", "label": "Link", "type": "textinput"}
        ]
      },
      {"name": "background_color", "label": "Background Color", "type": "textinput", "help": "Leave empty for transparent"}
    ]
  }
}
