{
  "title": "Linka Social Follow",
  "description": "Social media follow buttons with follower counts",
  "category": "social",
  "css_framework": "bootstrap",
  "config_schema": {
    "fields": [
      {
        "name": "networks",
        "label": "Social Networks",
        "type": "repeater",
        "fields": [
          {"name": "name", "label": "Network Name", "type": "textinput", "default": "Facebook"},
          {"name": "count", "label": "Count Text", "type": "textinput", "help": "e.g., 532k Like, 500k Followers", "default": "532k Like"},
          {"name": "icon", "label": "Icon Class", "type": "textinput", "help": "e.g., bx bxl-facebook", "default": "bx bxl-facebook"},
          {"name": "link", "label": "Profile Link", "type": "textinput", "default": "#"}
        ]
      }
    ]
  }
}
