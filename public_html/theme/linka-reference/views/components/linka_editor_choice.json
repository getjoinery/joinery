{
  "title": "Linka Editor's Choice",
  "description": "Editor's choice layout with main featured article and sidebar articles",
  "category": "blog",
  "icon": "bx bx-star",
  "css_framework": "bootstrap",
  "config_schema": {
    "fields": [
      {"name": "section_title", "label": "Section Title", "type": "textinput"},
      {"name": "background_color", "label": "Background Color", "type": "textinput", "help": "e.g., #f5f5f5 or leave empty"},
      {
        "name": "main_article",
        "label": "Main Featured Article",
        "type": "group",
        "fields": [
          {"name": "image", "label": "Image URL", "type": "textinput"},
          {"name": "title", "label": "Title", "type": "textinput"},
          {"name": "excerpt", "label": "Excerpt", "type": "textarea"},
          {"name": "date", "label": "Date", "type": "textinput"},
          {"name": "link", "label": "Link", "type": "textinput"}
        ]
      },
      {
        "name": "sidebar_articles",
        "label": "Sidebar Articles",
        "type": "repeater",
        "fields": [
          {"name": "image", "label": "Image URL", "type": "textinput"},
          {"name": "title", "label": "Title", "type": "textinput"},
          {"name": "date", "label": "Date", "type": "textinput"},
          {"name": "link", "label": "Link", "type": "textinput"}
        ]
      }
    ]
  }
}
