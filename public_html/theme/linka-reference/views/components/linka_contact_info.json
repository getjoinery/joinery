{
  "title": "Linka Contact Info",
  "description": "Contact information cards with icons - email, phone, location, live chat",
  "category": "contact",
  "css_framework": "bootstrap",
  "config_schema": {
    "fields": [
      {
        "name": "items",
        "label": "Contact Items",
        "type": "repeater",
        "fields": [
          {"name": "icon", "label": "Icon Class", "type": "textinput", "help": "BoxIcon class (e.g., bx bx-envelope)", "default": "bx bx-envelope"},
          {"name": "title", "label": "Title", "type": "textinput", "default": "Email Us"},
          {"name": "line1", "label": "Line 1", "type": "textinput", "default": "info@example.com"},
          {"name": "line1_link", "label": "Line 1 Link", "type": "textinput", "default": "mailto:info@example.com"},
          {"name": "line2", "label": "Line 2 (optional)", "type": "textinput", "default": "support@example.com"},
          {"name": "line2_link", "label": "Line 2 Link", "type": "textinput", "default": "mailto:support@example.com"}
        ]
      },
      {"name": "columns", "label": "Columns", "type": "dropinput", "default": "3", "options": {"2": "2 Columns", "3": "3 Columns", "4": "4 Columns"}}
    ]
  }
}
