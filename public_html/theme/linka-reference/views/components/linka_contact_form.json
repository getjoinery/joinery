{
  "title": "Linka Contact Form",
  "description": "Contact form with name, email, phone, subject, and message fields",
  "category": "forms",
  "css_framework": "bootstrap",
  "config_schema": {
    "fields": [
      {"name": "title", "label": "Form Title", "type": "textinput", "default": "Drop Us A Line"},
      {"name": "form_action", "label": "Form Action URL", "type": "textinput", "help": "Leave empty for default", "default": ""},
      {"name": "show_phone", "label": "Show Phone Field", "type": "checkboxinput", "default": true},
      {"name": "show_subject", "label": "Show Subject Field", "type": "checkboxinput", "default": true},
      {"name": "button_text", "label": "Button Text", "type": "textinput", "default": "Send Message"},
      {"name": "success_message", "label": "Success Message", "type": "textinput", "default": "Thank you for your message. We'll be in touch soon!"}
    ]
  }
}
