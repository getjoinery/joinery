{
  "title": "Linka Hero",
  "description": "Full-width hero section with background image, headline, and call-to-action",
  "category": "hero",
  "css_framework": "bootstrap",
  "config_schema": {
    "fields": [
      {"name": "title", "label": "Title", "type": "textinput", "default": "Why We Need Guidelines for Brain Scan Data"},
      {"name": "category", "label": "Category Badge", "type": "textinput", "help": "Category label shown on image", "default": "Lifestyle"},
      {"name": "author", "label": "Author Name", "type": "textinput", "default": "Jhona Walker"},
      {"name": "date", "label": "Date", "type": "textinput", "default": "25 Mar 2024"},
      {"name": "image", "label": "Background Image", "type": "textinput", "default": "/theme/linka-reference/assets/images/home-one/main-blog-img/1.jpg"},
      {"name": "link", "label": "Link URL", "type": "textinput", "help": "URL when clicking on title", "default": "#"},
      {"name": "min_height", "label": "Minimum Height", "type": "dropinput", "default": "500px", "options": {"400px": "Small (400px)", "500px": "Medium (500px)", "600px": "Large (600px)", "100vh": "Full Screen"}}
    ]
  }
}
