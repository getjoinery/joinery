{
  "name": "falcon-html5",
  "display_name": "Falcon HTML5 Theme",
  "version": "1.0.0",
  "description": "Vanilla HTML5+CSS version of Falcon — no Bootstrap, FontAwesome, jQuery, Simplebar, or Popper. ~98% smaller payload.",
  "author": "Joinery Team",
  "is_stock": true,
  "system": true,
  "requires": {
    "php": ">=7.4",
    "joinery": ">=1.0.0"
  },
  "cssFramework": "vanilla",
  "formWriterBase": "FormWriterBootstrap",
  "publicPageBase": "PublicPageFalconHtml5",
  "image_sizes": {
    "avatar": { "width": 80, "height": 80, "crop": true },
    "profile_card": { "width": 400, "height": 500, "crop": true },
    "content": { "width": 800, "height": 0, "crop": false },
    "hero": { "width": 1920, "height": 1080, "crop": true },
    "og_image": { "width": 1200, "height": 630, "crop": true }
  }
}
