{
    "name": "canvas",
    "display_name": "Canvas",
    "version": "1.0.0",
    "description": "Modern Bootstrap-based theme with Canvas template design",
    "author": "Canvas Theme",
    "parent_theme": "falcon",
    "framework": "bootstrap",
    "assets": {
        "css": [
            "assets/css/style.css",
            "assets/css/font-icons.css",
            "assets/css/swiper.css",
            "assets/css/custom.css"
        ],
        "js": [
            "assets/js/plugins.min.js",
            "assets/js/functions.bundle.js"
        ]
    },
    "features": {
        "responsive": true,
        "retina_ready": true,
        "parallax": true,
        "animations": true,
        "dark_mode": false
    },
    "config": {
        "primary_color": "#1ABC9C",
        "secondary_color": "#34495E",
        "font_family": "Inter, sans-serif",
        "heading_font": "Playfair Display, serif"
    }
}